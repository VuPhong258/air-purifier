# Public site URL (SEO, Open Graph, sitemap, robots)
NEXT_PUBLIC_SITE_URL=https://air-purifier-beta.vercel.app/

# Google Sheets via Apps Script. See scripts/google-sheets/Code.gs
GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Must match Script property SHEETS_SECRET in Apps Script (optional but recommended)
GOOGLE_SHEETS_SECRET=your-random-secret
